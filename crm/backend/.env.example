# ─────────────────────────────────────────────────────────────────────
# Tata Smartflo (Click-to-Call + recordings)
# Get these from your Tata account manager / Smartflo admin panel.
#
# Until at least TATA_API_BASE_URL + (TATA_API_TOKEN or TATA_API_KEY)
# are set, the call button works in "stub mode" — it inserts a calls
# row with a fake provider_call_id but does not dial a real call.
#
# Per-agent settings (account_type, extension, agent_number, caller_id)
# are stored on the CRM user row, NOT here. Set them in the
# Create/Edit User form for each Junior Caller / Senior Caller.
# ─────────────────────────────────────────────────────────────────────
TATA_API_BASE_URL=https://api-smartflo.tatatele.com
TATA_API_PATH=/v1/click_to_call_support
TATA_API_TOKEN=
TATA_API_KEY=
TATA_CALLER_ID=
TATA_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# NSM-Caller ▸ Zoom page — Zoom webinar ingest + Razorpay payment match.
# Until these are set the page renders but webhooks are no-ops:
#   • Zoom: a Server-to-Server OAuth app (marketplace.zoom.us). Same account
#     model as the webinar-dashboard app. Webhook secret is the app's
#     "Secret Token". Subscribe ONLY to webinar.registration_created +
#     webinar.ended. Webhook URL: <backend>/api/nsm-zoom-webhooks/zoom
#   • Razorpay: Dashboard → Settings → API Keys + Webhooks. Enable ONLY the
#     payment.captured event. URL: <backend>/api/nsm-zoom-webhooks/razorpay
# WHAPI_TOKEN (above, for NSM WhatsApp) is reused for the payment thank-you.
# ─────────────────────────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
